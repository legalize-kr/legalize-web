<!DOCTYPE html>
<html lang="ko">
<head>
{% set metaTitle = title or site.siteTitle %}
{% set metaDescription = description or '대한민국 법령 이미지 원본과 텍스트 변환 뷰어' %}
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ metaTitle }}</title>
<meta name="description" content="{{ metaDescription }}">
<link rel="canonical" href="https://legalize.kr{{ page.url }}">
<meta name="theme-color" content="#0F172A">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Legalize KR">
<meta property="og:locale" content="ko_KR">
<meta property="og:url" content="https://legalize.kr{{ page.url }}">
<meta property="og:title" content="{{ metaTitle }}">
<meta property="og:description" content="{{ metaDescription }}">
<meta property="og:image" content="https://legalize.kr/assets/og-image.png">
<meta property="og:image:secure_url" content="https://legalize.kr/assets/og-image.png">
<meta property="og:image:type" content="image/png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Legalize KR 메인 화면">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:url" content="https://legalize.kr{{ page.url }}">
<meta name="twitter:title" content="{{ metaTitle }}">
<meta name="twitter:description" content="{{ metaDescription }}">
<meta name="twitter:image" content="https://legalize.kr/assets/og-image.png">
<meta name="twitter:image:alt" content="Legalize KR 메인 화면">
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-S2FJBVDS6Y"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("js", new Date());

  gtag("config", "G-S2FJBVDS6Y");
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="nav">
  <a href="/" class="nav-logo">⚖ legalize.kr</a>
  <a href="/" class="nav-link">홈</a>
  <a href="/usage.html" class="nav-link{% if '/usage.html' in page.url %} active{% endif %}">활용법</a>
  <a href="/viewer.html" class="nav-link{% if '/viewer.html' in page.url %} active{% endif %}">문서 보기</a>
  <a href="/images/" class="nav-link{% if '/images/' in page.url %} active{% endif %}">이미지 뷰어</a>
  <span class="nav-spacer"></span>
  <a href="https://github.com/legalize-kr" class="nav-link" target="_blank" rel="noopener">GitHub</a>
</nav>

{{ content | safe }}

<footer class="footer">
  <p>
    <a href="https://github.com/legalize-kr/legalize-kr">legalize-kr</a> ·
    데이터 출처: <a href="https://open.law.go.kr" target="_blank" rel="noopener">국가법령정보센터 OpenAPI</a>
  </p>
</footer>
</body>
</html>
